    function Preview:FitCamera(Size)
        local ViewportSize = self.Viewport.AbsoluteSize
        if ViewportSize.X <= 1 or ViewportSize.Y <= 1 then return end
        local VerticalFov = math.rad(self.Camera.FieldOfView)
        local Aspect = ViewportSize.X / math.max(ViewportSize.Y, 1)
        local HorizontalFov = 2 * math.atan(math.tan(VerticalFov * 0.5) * Aspect)
        local HalfWidth = math.max(Size.X, Size.Z) * 0.5
        local HalfHeight = Size.Y * 0.5
        local HalfDepth = math.max(Size.X, Size.Z) * 0.5
        local VerticalDistance = HalfHeight / math.tan(VerticalFov * 0.5)
        local HorizontalDistance = HalfWidth / math.tan(HorizontalFov * 0.5)
        local Distance = (math.max(VerticalDistance, HorizontalDistance) + HalfDepth) * 1.22
        self.Camera.CFrame = CFrame.lookAt(Vector3.new(0, 0, -Distance), Vector3.zero)
        self.CameraReady = true
    end

    function Preview:BuildCharacter()
        self.World:ClearAllChildren()
        table.clear(self.Data.Parts)

        local Model = Instance.new("Model")
        Model.Name = "BowserPreviewModel"

        local Success, Loaded = pcall(function()
            return game:GetObjects("rbxassetid://430331589")
        end)
        local Asset = Success and type(Loaded) == "table" and Loaded[1] or nil

        if Asset then
            if Asset:IsA("Model") then
                Model:Destroy()
                Model = Asset
                Model.Name = "BowserPreviewModel"
            elseif Asset:IsA("DataModelMesh") then
                local Part = Instance.new("Part")
                Part.Name = "Bowser"
                Part.Size = Vector3.new(6, 6, 6)
                Part.Anchored = true
                Part.CanCollide = false
                Asset.Parent = Part
                Part.Parent = Model
            else
                local ParentSuccess = pcall(function()
                    Asset.Parent = Model
                end)
                if not ParentSuccess then
                    for _, Descendant in Asset:GetDescendants() do
                        if Descendant:IsA("BasePart") then
                            Descendant:Clone().Parent = Model
                        end
                    end
                    Asset:Destroy()
                end
            end
        end

        local Parts = {}
        local function Prepare(Object)
            if Object:IsA("Script") or Object:IsA("LocalScript") or Object:IsA("ModuleScript") then
                Object:Destroy()
            elseif Object:IsA("ParticleEmitter") or Object:IsA("Trail") or Object:IsA("Beam") or Object:IsA("Smoke") or Object:IsA("Fire") or Object:IsA("Sparkles") then
                Object.Enabled = false
            elseif Object:IsA("BasePart") then
                Object.Anchored = true
                Object.CanCollide = false
                Object.CanTouch = false
                Object.CanQuery = false
                Object.CastShadow = false
                table.insert(Parts, Object)
            end
        end

        Prepare(Model)
        for _, Descendant in Model:GetDescendants() do
            Prepare(Descendant)
        end

        if #Parts == 0 then
            Model:ClearAllChildren()
            local Part = Instance.new("Part")
            Part.Name = "Bowser"
            Part.Size = Vector3.new(6, 6, 6)
            Part.Anchored = true
            Part.CanCollide = false
            Part.CanTouch = false
            Part.CanQuery = false
            Part.CastShadow = false
            Part.Transparency = 1
            Part.Parent = Model
            local Mesh = Instance.new("SpecialMesh")
            Mesh.MeshType = Enum.MeshType.FileMesh
            Mesh.MeshId = "rbxassetid://430331589"
            Mesh.Parent = Part
            table.insert(Parts, Part)
        end

        Model.Parent = self.World

        local function CalculateBounds(VisibleOnly)
            local Minimum = Vector3.new(math.huge, math.huge, math.huge)
            local Maximum = Vector3.new(-math.huge, -math.huge, -math.huge)
            local Found = false
            for _, Part in Parts do
                if Part and Part.Parent and (not VisibleOnly or (Part.Transparency < 1 and Part.Name ~= "HumanoidRootPart")) then
                    local Half = Part.Size * 0.5
                    for X = -1, 1, 2 do
                        for Y = -1, 1, 2 do
                            for Z = -1, 1, 2 do
                                local Point = Part.CFrame:PointToWorldSpace(Vector3.new(Half.X * X, Half.Y * Y, Half.Z * Z))
                                Minimum = Vector3.new(
                                    math.min(Minimum.X, Point.X),
                                    math.min(Minimum.Y, Point.Y),
                                    math.min(Minimum.Z, Point.Z)
                                )
                                Maximum = Vector3.new(
                                    math.max(Maximum.X, Point.X),
                                    math.max(Maximum.Y, Point.Y),
                                    math.max(Maximum.Z, Point.Z)
                                )
                                Found = true
                            end
                        end
                    end
                end
            end
            if not Found then return nil end
            return (Minimum + Maximum) * 0.5, Maximum - Minimum
        end

        local Center, CenteredSize = CalculateBounds(true)
        if not Center then
            Center, CenteredSize = CalculateBounds(false)
        end
        Center = Center or Vector3.zero
        CenteredSize = CenteredSize or Vector3.new(6, 6, 6)

        local Shift = CFrame.new(-Center)
        for _, Part in Parts do
            if Part and Part.Parent then
                Part.CFrame = Shift * Part.CFrame
            end
        end

        for _, Part in Parts do
            if Part and Part.Parent then
                table.insert(self.Data.Parts, {Part = Part, Relative = Part.CFrame})
            end
        end

        self.Data.Clone = Model
        self.Data.Size = CenteredSize
        self.CameraReady = false
        self:FitCamera(CenteredSize)
        task.defer(function()
            if self.Data.Size then
                self:FitCamera(self.Data.Size)
            end
        end)
    end

    function Preview:GetBounds()
        local Size = self.Viewport.AbsoluteSize
        if Size.X <= 1 or Size.Y <= 1 then return end
        local FocalLength = Size.Y / (2 * math.tan(math.rad(self.Camera.FieldOfView) * 0.5))
        local CameraCFrame = self.Camera.CFrame
        local MinimumX, MinimumY = math.huge, math.huge
        local MaximumX, MaximumY = -math.huge, -math.huge
        local Found = false

        for _, Mapping in self.Data.Parts do
            local Part = Mapping.Part
            if Part.Parent and Part.Transparency < 1 and Part.Name ~= "HumanoidRootPart" then
                local Center = CameraCFrame:PointToObjectSpace(Part.Position)
                local Depth = -Center.Z
                if Depth > 0.01 then
                    local Half = Part.Size * 0.5
                    local Right = CameraCFrame:VectorToObjectSpace(Part.CFrame.RightVector)
                    local Up = CameraCFrame:VectorToObjectSpace(Part.CFrame.UpVector)
                    local Look = CameraCFrame:VectorToObjectSpace(Part.CFrame.LookVector)
                    local Scale = FocalLength / Depth
                    local ExtendX = (math.abs(Right.X * Half.X) + math.abs(Up.X * Half.Y) + math.abs(Look.X * Half.Z)) * Scale
                    local ExtendY = (math.abs(Right.Y * Half.X) + math.abs(Up.Y * Half.Y) + math.abs(Look.Y * Half.Z)) * Scale
                    local X = Size.X * 0.5 + Center.X * Scale
                    local Y = Size.Y * 0.5 - Center.Y * Scale
                    MinimumX, MaximumX = math.min(MinimumX, X - ExtendX), math.max(MaximumX, X + ExtendX)
                    MinimumY, MaximumY = math.min(MinimumY, Y - ExtendY), math.max(MaximumY, Y + ExtendY)
                    Found = true
                end
            end
        end
        if not Found then return end
        local Bounding = Controller.Table.Boxes["Bounding Box"]
        local PaddingX, PaddingY = Bounding.BoxX or 0, Bounding.BoxY or 0
        return math.floor(MinimumX - PaddingX * 0.5), math.floor(MinimumY - PaddingY * 0.5),
            math.max(1, math.floor(MaximumX - MinimumX + PaddingX)),
            math.max(1, math.floor(MaximumY - MinimumY + PaddingY))
    end

    function Preview:Refresh()
        local Objects = self.Data.Objects
