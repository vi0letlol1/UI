    Holder.BackgroundColor3 = Color3.fromRGB(18, 18, 20)
    Holder.BorderSizePixel = 0
    Holder.Size = UDim2.new(1, 0, 0, 310)
    Holder.Parent = options.parent or (self.items and self.items.elements)

    local Corner = Instance.new("UICorner")
