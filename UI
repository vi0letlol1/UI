    local function decimal_places(step)
        step = math.abs(tonumber(step) or 1)

        for places = 0, 6 do
            local scaled = step * (10 ^ places)
            if math.abs(scaled - math.floor(scaled + 0.5)) < 1e-7 then
                return places
            end
        end

        return 6
    end

    local function format_number(value, places)
        if places <= 0 then
            return tostring(math.floor(value + 0.5))
        end

        return string.format("%." .. tostring(places) .. "f", value)
    end

    local function clamped_popup_position(anchor, width, height, prefer_right)
        local viewport = camera.ViewportSize
        local margin = 8
        local anchor_position = anchor.AbsolutePosition
        local anchor_size = anchor.AbsoluteSize
        local x

        if prefer_right then
            x = anchor_position.X + anchor_size.X + margin
            if x + width > viewport.X - margin then
                x = anchor_position.X - width - margin
            end
        else
            x = anchor_position.X
            if x + width > viewport.X - margin then
                x = viewport.X - width - margin
            end
        end

        local y = anchor_position.Y - margin
        if y + height > viewport.Y - margin then
            y = viewport.Y - height - margin
        end

        x = clamp(x, margin, math.max(margin, viewport.X - width - margin))
        y = clamp(y, margin, math.max(margin, viewport.Y - height - margin))

        return dim_offset(x, y)
    end

