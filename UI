        function library:draggify(frame, drag_handle)
            drag_handle = drag_handle or frame

            local dragging = false
            local active_input
            local start_position
            local start_pointer

            local function finish_drag(input)
                if not dragging then
                    return
                end

                if not input or input == active_input or input.UserInputType == Enum.UserInputType.MouseButton1 then
                    dragging = false
                    active_input = nil
                end
            end

            drag_handle.InputBegan:Connect(function(input)
                if not is_primary_pointer(input) then
                    return
                end

                dragging = true
                active_input = input
                start_pointer = pointer_position(input)
                start_position = frame.Position

                input.Changed:Connect(function()
                    if input.UserInputState == Enum.UserInputState.End then
                        finish_drag(input)
                    end
                end)
            end)

            library:connection(uis.InputChanged, function(input)
                if not dragging or not is_pointer_movement(input) then
                    return
                end

                if active_input and active_input.UserInputType == Enum.UserInputType.Touch and input ~= active_input then
                    return
                end

                local current_pointer = pointer_position(input)
                local viewport = camera.ViewportSize
                local frame_size = frame.AbsoluteSize
                local x = start_position.X.Offset + (current_pointer.X - start_pointer.X)
                local y = start_position.Y.Offset + (current_pointer.Y - start_pointer.Y)

                frame.Position = dim_offset(
                    clamp(x, 0, math.max(0, viewport.X - frame_size.X)),
                    clamp(y, 0, math.max(0, viewport.Y - frame_size.Y))
                )
                library:close_element()
            end)

            library:connection(uis.InputEnded, finish_drag)
        end

        function library:convert(str)
            local values = {}

            for value in string.gmatch(str, "[^,]+") do
                insert(values, tonumber(value))
            end

            if #values == 4 then
                return unpack(values)
            else
                return
            end
        end

        function library:convert_enum(enum)
            local enum_parts = {}

            for part in string.gmatch(enum, "[%w_]+") do
                insert(enum_parts, part)
            end

            local enum_table = Enum
            for i = 2, #enum_parts do
                local enum_item = enum_table[enum_parts[i]]

                enum_table = enum_item
            end

            return enum_table
        end

