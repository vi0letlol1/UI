        local function make_title_gradient()
            local white = rgb(255, 255, 255)

            return rgbseq({
                rgbkey(0, themes.preset.accent),
                rgbkey(0.30, themes.preset.accent:Lerp(white, 0.28)),
                rgbkey(0.50, white),
                rgbkey(0.72, themes.preset.title_gradient:Lerp(white, 0.22)),
                rgbkey(1, themes.preset.title_gradient),
            })
        end

        local function register_title_gradient(gradient)
            insert(themes.title_gradients, gradient)
            gradient.Color = make_title_gradient()
        end

        local function refresh_title_gradients()
            for index = #themes.title_gradients, 1, -1 do
                local gradient = themes.title_gradients[index]
                if gradient and gradient.Parent then
                    gradient.Color = make_title_gradient()
                else
                    remove(themes.title_gradients, index)
                end
            end
        end

        function library:update_theme(theme, new_color)
            if theme == "title_gradient" then
                themes.preset.title_gradient = new_color
                refresh_title_gradients()
                return
            end

            local old_color = themes.preset[theme]
            local theme_data = themes.utility[theme]

            if theme_data then
                for property_name, objects in theme_data do
                    for index = #objects, 1, -1 do
                        local object = objects[index]
                        if not object or not object.Parent then
                            remove(objects, index)
                        elseif object[property_name] == old_color then
                            object[property_name] = new_color
                        end
                    end
                end
            end

            themes.preset[theme] = new_color
            refresh_title_gradients()
        end

        function library:connection(signal, callback)
