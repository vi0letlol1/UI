            end

            if inline_keybind ~= nil and inline_keybind ~= false then
                local keybind_options

                if type(inline_keybind) == "table" then
                    keybind_options = inline_keybind
                elseif inline_keybind ~= true then
                    keybind_options = {default = inline_keybind}
                else
