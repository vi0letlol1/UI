function library:esp_preview(options)
    options = options or {}
    local Controller = options.controller
    local Flags = options.flags or library.flags
    local Sync = options.sync or function() end
    if type(Controller) ~= "table" or type(Controller.InitEsp) ~= "function" then
        return nil
    end
    local Holder = Instance.new("Frame")
    Holder.Name = "\0"
