        Objects.TargetName.Visible = Texts.Name.Enabled
        Objects.TargetName.Text = "bowser"
        Objects.TargetNameGradient.Color = ColorSequence.new(Texts.Name.Top, Texts.Name.Bot)
        Objects.PlayerIcon.Visible = false
        Objects.Distance.Visible = Texts.Distance.Enabled
