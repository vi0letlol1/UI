        function library:resizify(frame)
            local handle_size = mobile_value(14, 28)
            local handle = Instance.new("TextButton")
            handle.Position = dim2(1, -handle_size, 1, -handle_size)
            handle.BorderColor3 = rgb(0, 0, 0)
            handle.Size = dim2(0, handle_size, 0, handle_size)
            handle.BorderSizePixel = 0
            handle.BackgroundColor3 = rgb(255, 255, 255)
            handle.Parent = frame
            handle.BackgroundTransparency = 1
            handle.Text = ""
            handle.AutoButtonColor = false
            handle.ZIndex = 100

            local resizing = false
            local active_input
            local start_size
            local start_position
            local minimum_size = frame.Size

            local function finish_resize(input)
                if not resizing then
                    return
                end

                if not input or input == active_input or input.UserInputType == Enum.UserInputType.MouseButton1 then
                    resizing = false
                    active_input = nil
                end
            end

            handle.InputBegan:Connect(function(input)
                if not is_primary_pointer(input) then
                    return
                end

                resizing = true
                active_input = input
                start_position = pointer_position(input)
                start_size = frame.Size

                input.Changed:Connect(function()
                    if input.UserInputState == Enum.UserInputState.End then
                        finish_resize(input)
                    end
                end)
            end)

            library:connection(uis.InputChanged, function(input)
                if not resizing or not is_pointer_movement(input) then
                    return
                end

                if active_input and active_input.UserInputType == Enum.UserInputType.Touch and input ~= active_input then
                    return
                end

                local current_position = pointer_position(input)
                local scale_object = frame:FindFirstChildOfClass("UIScale")
                local scale = scale_object and math.max(scale_object.Scale, 0.01) or 1
                local viewport = camera.ViewportSize
                local delta_x = (current_position.X - start_position.X) / scale
                local delta_y = (current_position.Y - start_position.Y) / scale

                local max_width = math.max(minimum_size.X.Offset, viewport.X / scale)
                local max_height = math.max(minimum_size.Y.Offset, viewport.Y / scale)
                local current_size = dim2(
                    start_size.X.Scale,
                    clamp(start_size.X.Offset + delta_x, minimum_size.X.Offset, max_width),
                    start_size.Y.Scale,
                    clamp(start_size.Y.Offset + delta_y, minimum_size.Y.Offset, max_height)
                )

                frame.Size = current_size
            end)

            library:connection(uis.InputEnded, finish_resize)
        end

