                        items["key"].Text = display_key(cfg.key)
                        update_flag()
                    end
                    return
                end

                if type(input) == "table" then
                    if input.key ~= nil then
                        cfg.key = resolve_key(input.key)
                    end
                    if input.mode ~= nil and table.find(mode_options, input.mode) then
                        cfg.mode = input.mode
                    end
                    if input.active ~= nil then
                        cfg.active = input.active == true
                    end

                    items["key"].Text = display_key(cfg.key)
                    update_mode_colors()
                    apply_active(cfg.active, false)
                end
            end

            function cfg.set_visible(visible, internal_close)
                cfg.open = visible == true
                local dropdown = items["dropdown"]

                if not cfg.open then
                    library:tween(dropdown, {Size = dim2(0, 92, 0, 0)}, Enum.EasingStyle.Quad, 0.15)
                    task.delay(0.16, function()
                        if not cfg.open and dropdown and dropdown.Parent then
                            dropdown.Visible = false
                        end
                    end)
                    if library.current_open == cfg then
                        library.current_open = cfg.parent_settings
                    end
                    return
                end

                local viewport = camera.ViewportSize
                local width = 92
                local height = 70
                local x = math.clamp(items["keybind_holder"].AbsolutePosition.X, 4, math.max(4, viewport.X - width - 4))
                local y = items["keybind_holder"].AbsolutePosition.Y + items["keybind_holder"].AbsoluteSize.Y + 4

                if y + height > viewport.Y - 4 then
                    y = items["keybind_holder"].AbsolutePosition.Y - height - 4
                end

                dropdown.Position = dim2(0, x, 0, math.max(4, y))
                dropdown.Size = dim2(0, width, 0, 0)
                dropdown.Visible = true
                library:tween(dropdown, {Size = dim2(0, width, 0, height)}, Enum.EasingStyle.Quad, 0.2)

                if not internal_close then
                    library:close_element(cfg)
                end
            end

            local function begin_binding()


                if uis:GetLastInputType() == Enum.UserInputType.Touch and not uis.KeyboardEnabled then
                    return
                end

                if cfg.binding then
                    cfg.binding:Disconnect()
                    cfg.binding = nil
                end

                items["key"].Text = "..."
                cfg.binding = library:connection(uis.InputBegan, function(input, processed)
                    if input.UserInputType == Enum.UserInputType.Touch then
                        return
                    end

                    local selected_key = input.UserInputType == Enum.UserInputType.Keyboard
                        and input.KeyCode
                        or input.UserInputType

                    cfg.key = selected_key == Enum.KeyCode.Escape and "NONE" or selected_key
                    items["key"].Text = display_key(cfg.key)
                    update_flag()

                    cfg.binding:Disconnect()
                    cfg.binding = nil
                end)
            end

            items["keybind_holder"].Activated:Connect(begin_binding)
            items["keybind_holder"].MouseButton2Click:Connect(function()
                cfg.set_visible(not cfg.open)
            end)

            library:connection(uis.InputBegan, function(input)
                if not cfg.open or library.current_open ~= cfg or not is_dismiss_pointer(input) then
                    return
                end

                local position = pointer_position(input)
                task.defer(function()
                    if cfg.open and library.current_open == cfg
                        and not pointer_in_gui(position, items["dropdown"])
                        and not pointer_in_gui(position, items["keybind_holder"]) then
                        cfg.set_visible(false)
                    end
                end)
            end)

            library:connection(uis.InputBegan, function(input, processed)
                if processed or cfg.binding then
                    return
                end

                local selected_key = input.UserInputType == Enum.UserInputType.Keyboard
                    and input.KeyCode
                    or input.UserInputType

                if selected_key ~= cfg.key then
                    return
                end

                if cfg.mode == "Toggle" then
                    local current = cfg.attached_toggle and cfg.attached_toggle.enabled or cfg.active
                    apply_active(not current)
                elseif cfg.mode == "Hold" then
                    apply_active(true)
                elseif cfg.mode == "Always" then
                    apply_active(true)
                end
            end)

            library:connection(uis.InputEnded, function(input, processed)
                if processed or cfg.mode ~= "Hold" then
                    return
                end

                local selected_key = input.UserInputType == Enum.UserInputType.Keyboard
                    and input.KeyCode
                    or input.UserInputType

                if selected_key == cfg.key then
                    apply_active(false)
                end
            end)

            items["key"].Text = display_key(cfg.key)
            update_mode_colors()
            if cfg.mode == "Always" then
                apply_active(true, false)
            else
                update_flag()
            end

            config_flags[cfg.flag] = cfg.set

            local result = setmetatable(cfg, library)
            if attached_toggle then
                self._keybind_control = result
            end

            return result
        end

