    function Preview:UpdateCharacter(DeltaTime)
        if not self.DraggingModel and not self.DraggingElement then
            self.Yaw += DeltaTime * 0.72
        end
        local Rotation = CFrame.Angles(0, self.Yaw, 0)
        for _, Mapping in self.Data.Parts do
            if Mapping.Part and Mapping.Part.Parent then
                Mapping.Part.CFrame = Rotation * Mapping.Relative
            end
        end
    end

    function Preview:GetElementBounds(Element)
        local MinimumX, MinimumY = math.huge, math.huge
        local MaximumX, MaximumY = -math.huge, -math.huge
        local Found = false
        local function Include(Object)
            if not Object:IsA("GuiObject") or not Object.Visible then return end
            local Position = Object.AbsolutePosition
            local Size = Object.AbsoluteSize
            if Size.X <= 0 or Size.Y <= 0 then return end
            MinimumX = math.min(MinimumX, Position.X)
            MinimumY = math.min(MinimumY, Position.Y)
            MaximumX = math.max(MaximumX, Position.X + Size.X)
            MaximumY = math.max(MaximumY, Position.Y + Size.Y)
            Found = true
        end
        Include(Element)
        for _, Descendant in Element:GetDescendants() do
            Include(Descendant)
        end
        if not Found then return end
        return MinimumX, MinimumY, MaximumX, MaximumY
    end

    function Preview:GetLayoutElement(Position)
        local Elements = Controller:GetLayoutObjects(self.Data.Objects)
        local BestKey, BestElement, BestArea
        for Key, Element in Elements do
            if Element and Element.Visible then
                local Left, Top, Right, Bottom = self:GetElementBounds(Element)
                if Left then
                    local Margin = Controller:IsBarKey(Key) and 13 or 7
                    Left -= Margin
                    Top -= Margin
                    Right += Margin
                    Bottom += Margin
                    if Position.X >= Left and Position.X <= Right and Position.Y >= Top and Position.Y <= Bottom then
                        local Area = math.max(1, Right - Left) * math.max(1, Bottom - Top)
                        if not BestArea or Area < BestArea then
                            BestKey = Key
                            BestElement = Element
                            BestArea = Area
                        end
                    end
                end
            end
        end
        return BestKey, BestElement
    end

    function Preview:IsInsideOverlay(Position)
        local ObjectPosition = self.Overlay.AbsolutePosition
        local ObjectSize = self.Overlay.AbsoluteSize
        return Position.X >= ObjectPosition.X
            and Position.X <= ObjectPosition.X + ObjectSize.X
            and Position.Y >= ObjectPosition.Y
            and Position.Y <= ObjectPosition.Y + ObjectSize.Y
    end

    function Preview:IsVisible()
        local Current = self.Holder
        while Current do
            if Current:IsA("GuiObject") and Current.Visible == false then return false end
            if Current:IsA("LayerCollector") and Current.Enabled == false then return false end
            Current = Current.Parent
        end
        return self.Holder.Parent ~= nil and self.Viewport.AbsoluteSize.X > 1 and self.Viewport.AbsoluteSize.Y > 1
    end

    function Preview:GetFlagSignature()
        local Values = {}
        for Key, Value in Flags do
            if string.sub(tostring(Key), 1, 4) == "esp_" then
                local Text
                if type(Value) == "table" then
                    Text = tostring(Value.Color or Value.color or "")
                        .. ":" .. tostring(Value.Transparency or Value.transparency or "")
                        .. ":" .. tostring(Value.mode or "")
                        .. ":" .. tostring(Value.key or "")
                        .. ":" .. tostring(Value.active or "")
                else
                    Text = tostring(Value)
                end
                table.insert(Values, tostring(Key) .. "=" .. Text)
            end
        end
        table.sort(Values)
        return table.concat(Values, "|")
    end

    function Preview:GetNearestZone(Position)
        local Target = self.Data.Objects.TargetHolder
        local Left = Target.AbsolutePosition.X
        local Top = Target.AbsolutePosition.Y
        local Right = Left + Target.AbsoluteSize.X
        local Bottom = Top + Target.AbsoluteSize.Y
        local Third = Target.AbsoluteSize.X / 3

        if Position.Y < Top then
            if Position.X < Left + Third then return "TopLeft" end
            if Position.X > Right - Third then return "TopRight" end
            return "Top"
        elseif Position.Y > Bottom then
            if Position.X < Left + Third then return "BottomLeft" end
            if Position.X > Right - Third then return "BottomRight" end
            return "Bottom"
        elseif Position.X < (Left + Right) * 0.5 then
            return "Left"
        end
        return "Right"
    end

    function Preview:StartElementDrag(Key, Element, Position)
        self.DraggingElement = Key
        self.DragElement = Element
        self.DragOriginalZIndex = Element.ZIndex
        self.DragOffset = Vector2.new(Position.X, Position.Y) - Element.AbsolutePosition
        local Absolute = Element.AbsolutePosition - self.Overlay.AbsolutePosition
        Element.Parent = self.Overlay
        Element.AnchorPoint = Vector2.zero
        Element.Position = UDim2.fromOffset(Absolute.X, Absolute.Y)
        Element.ZIndex = 200
    end

    function Preview:MoveElement(Position)
        if not self.DragElement then return end
        local Local = Vector2.new(Position.X, Position.Y) - self.Overlay.AbsolutePosition - self.DragOffset
        local OverlaySize = self.Overlay.AbsoluteSize
        local ElementSize = self.DragElement.AbsoluteSize
        local Padding = 10
        local X = math.clamp(Local.X, -Padding, OverlaySize.X - ElementSize.X + Padding)
        local Y = math.clamp(Local.Y, -Padding, OverlaySize.Y - ElementSize.Y + Padding)
        self.DragElement.Position = UDim2.fromOffset(X, Y)
    end

    function Preview:FinishElementDrag(Position)
        local Key = self.DraggingElement
        if not Key then return end
        local Zone = self:GetNearestZone(Position)
        local Entry = Controller.Table.Layout[Key]
        if Entry then
            Entry.Zone = Zone
            Flags["esp_layout_" .. string.lower(Key) .. "_zone"] = Zone
        end
        if self.DragElement and self.DragOriginalZIndex then
            self.DragElement.ZIndex = self.DragOriginalZIndex
        end
        self.DraggingElement = nil
        self.DragElement = nil
        self.DragOffset = nil
        self.DragOriginalZIndex = nil
        Controller:ApplyLayout(self.Data)
    end

    function Preview:Destroy()
        for _, Connection in self.Connections do
            if Connection and Connection.Connected then
                Connection:Disconnect()
            end
        end
        table.clear(self.Connections)
        if self.Holder and self.Holder.Parent then
            self.Holder:Destroy()
        end
    end

    Preview:BuildCharacter()
    table.insert(Preview.Connections, uis.InputBegan:Connect(function(Input)
        local Primary = Input.UserInputType == Enum.UserInputType.MouseButton1
            or Input.UserInputType == Enum.UserInputType.Touch
        if not Primary then return end
        local Key, Element = Preview:GetLayoutElement(Input.Position)
        if Key then
            Preview.DragInput = Input
            Preview:StartElementDrag(Key, Element, Input.Position)
        elseif Preview:IsInsideOverlay(Input.Position) then
            Preview.DraggingModel = true
            Preview.DragInput = Input
            Preview.LastPointerX = Input.Position.X
        end
    end))
    table.insert(Preview.Connections, uis.InputChanged:Connect(function(Input)
        local Movement = Input.UserInputType == Enum.UserInputType.MouseMovement
            or Input.UserInputType == Enum.UserInputType.Touch
        if not Movement then return end
        if Preview.DragInput and Preview.DragInput.UserInputType == Enum.UserInputType.Touch and Input ~= Preview.DragInput then return end
        if Preview.DraggingElement then
            Preview:MoveElement(Input.Position)
        elseif Preview.DraggingModel then
            Preview.Yaw += (Input.Position.X - Preview.LastPointerX) * 0.012
            Preview.LastPointerX = Input.Position.X
        end
    end))
