        function library:close_element(new_path)
            local open_element = library.current_open

            if not new_path then
                while open_element do
                    if open_element.set_visible then
                        open_element.set_visible(false, true)
                    end
                    open_element.open = false
                    open_element = open_element.parent_settings
                end

                library.current_open = nil
                return
            end

            if open_element and new_path ~= open_element then
                local element_to_close = open_element

                while element_to_close
                    and element_to_close ~= new_path
                    and not settings_is_ancestor(element_to_close, new_path) do
                    if element_to_close.set_visible then
                        element_to_close.set_visible(false, true)
                    end
                    element_to_close.open = false
                    element_to_close = element_to_close.parent_settings
                end
            end

            library.current_open = new_path
        end

